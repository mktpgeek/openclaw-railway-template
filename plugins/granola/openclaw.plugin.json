{
  "id": "granola",
  "name": "Granola",
  "description": "Granola meeting notes tools for OpenClaw",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string"
      },
      "baseUrl": {
        "type": "string"
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "label": "Granola API key",
      "placeholder": "grn_...",
      "sensitive": true
    },
    "baseUrl": {
      "label": "Granola API base URL",
      "placeholder": "https://public-api.granola.ai/v1"
    }
  },
  "contracts": {
    "tools": [
      "granola_list_notes",
      "granola_get_note",
      "granola_search_notes"
    ]
  }
}
